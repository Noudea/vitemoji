{
  "name": "vitemoji",
  "version": "0.0.0",
  "description": "A playful Vite plugin for UI text transforms.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/runtime/react.d.ts",
      "import": "./dist/runtime/react.js"
    }
  },
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "node ./scripts/generate-emoji-data.mjs && tsc -p tsconfig.build.json",
    "generate:data": "node ./scripts/generate-emoji-data.mjs",
    "test": "node ./scripts/generate-emoji-data.mjs && vitest run",
    "typecheck": "node ./scripts/generate-emoji-data.mjs && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "emojibase-data": "^17.0.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
