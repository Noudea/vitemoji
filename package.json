{
  "name": "vitemoji-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter vitemoji build && pnpm --filter playground build",
    "docs:build": "pnpm --filter docs build",
    "docs:dev": "pnpm --filter docs dev",
    "dev": "pnpm generate:data && pnpm --filter playground dev",
    "format": "pnpm exec biome format . --write",
    "generate:data": "pnpm --filter vitemoji generate:data",
    "lint": "pnpm exec biome check .",
    "lint:fix": "pnpm exec biome check . --write",
    "test": "pnpm --filter vitemoji test",
    "typecheck": "pnpm --filter vitemoji typecheck && pnpm --filter playground typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21"
  }
}
